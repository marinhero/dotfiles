// jira.kdl — default layout for ticket-named sessions launched via `zj`.
// Three tabs: CLAUDE (Claude Code), SHELL (plain shell), MISC (plain shell).
// Applied only when a session is first CREATED; resurrected sessions restore
// their serialized tabs instead.
//
// A custom layout REPLACES zellij's default, so we add the bar plugin ourselves
// via default_tab_template — otherwise tabs are invisible. Use the single-line
// compact-bar to match the global `default_layout "compact"` look (not the
// taller tab-bar + status-bar pair).
layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
    }

    tab name="CLAUDE" focus=true {
        // Skip permission checks by default, matching the `cc` shell function.
        // A pane command bypasses the shell, so the flag is set explicitly here.
        pane command="claude" {
            args "--model" "us.anthropic.claude-opus-4-8[1m]" "--dangerously-skip-permissions"
        }
    }
    tab name="SHELL" {
        pane
    }
    tab name="MISC" {
        pane
    }
}
