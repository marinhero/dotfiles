#!/bin/sh

# -----------------------------------------------------------
# bspwm configuration
# -----------------------------------------------------------

# Hotkey daemon
pgrep -x sxhkd > /dev/null || sxhkd &

# Compositor (if installed)
pgrep -x picom > /dev/null || picom --backend glx --vsync &

# Workspaces
bspc monitor -d 1 2 3 4 5 6 7 8 9 0

# -----------------------------------------------------------
# Window settings
# -----------------------------------------------------------

bspc config border_width         3
bspc config window_gap           10

bspc config top_padding          32
bspc config bottom_padding       0
bspc config left_padding         0
bspc config right_padding        0

bspc config split_ratio          0.52
bspc config borderless_monocle   true
bspc config gapless_monocle      false
bspc config single_monocle       true

# -----------------------------------------------------------
# Focus settings
# -----------------------------------------------------------

bspc config focus_follows_pointer true
bspc config pointer_modifier      mod4

# -----------------------------------------------------------
# Colors (Nord)
# -----------------------------------------------------------

bspc config normal_border_color   "#2e3440"
bspc config active_border_color   "#3b4252"
bspc config focused_border_color  "#88c0d0"
bspc config presel_feedback_color "#d8dee9"

# -----------------------------------------------------------
# Rules
# -----------------------------------------------------------

bspc rule -a Gimp desktop='^8' state=floating follow=on
bspc rule -a Firefox desktop='^2'
bspc rule -a Chromium desktop='^2'
bspc rule -a Slack desktop='^3'
bspc rule -a discord desktop='^4'
bspc rule -a Spotify desktop='^5'

# Floating windows
bspc rule -a Pavucontrol state=floating
bspc rule -a Nm-connection-editor state=floating
bspc rule -a File-roller state=floating

# -----------------------------------------------------------
# Autostart
# -----------------------------------------------------------

# Random wallpaper
~/.local/bin/random-wallpaper &

# Remap Caps Lock to Ctrl
setxkbmap -option ctrl:nocaps &

# Set cursor
xsetroot -cursor_name left_ptr &

# Clipboard manager
pgrep -x greenclip > /dev/null || greenclip daemon &

# Status bar
~/.config/polybar/launch.sh &
