#------------FZF-----------------
# Source fzf key-bindings (Ctrl-R history search, Ctrl-T file search, Alt-C cd)
# and completions. Check asdf install first, then platform-specific fallbacks.
_fzf_sourced=0

# asdf-managed fzf
if command -v asdf &>/dev/null; then
  _fzf_asdf_dir="$(asdf where fzf 2>/dev/null)/shell"
  if [[ -d "$_fzf_asdf_dir" ]]; then
    [[ -f "$_fzf_asdf_dir/key-bindings.zsh" ]] && source "$_fzf_asdf_dir/key-bindings.zsh"
    [[ -f "$_fzf_asdf_dir/completion.zsh" ]]   && source "$_fzf_asdf_dir/completion.zsh"
    _fzf_sourced=1
  fi
  unset _fzf_asdf_dir
fi

# Fallback to system install
if (( ! _fzf_sourced )) && command -v fzf &>/dev/null; then
  # fzf >= 0.48 ships its own shell integration via `fzf --zsh` — prefer it.
  if fzf --zsh &>/dev/null; then
    source <(fzf --zsh)
    _fzf_sourced=1
  else
    # Older fzf: source the packaged shell files. Covers Homebrew,
    # Termux ($PREFIX/share/fzf), Debian/Ubuntu (/usr/share/doc/fzf/examples),
    # and other distros (/usr/share/fzf[/shell]).
    for fzf_dir in \
      /opt/homebrew/opt/fzf/shell /usr/local/opt/fzf/shell \
      "${PREFIX:-/usr}/share/fzf" \
      /usr/share/fzf/shell /usr/share/fzf \
      /usr/share/doc/fzf/examples; do
      if [[ -f "$fzf_dir/key-bindings.zsh" ]]; then
        source "$fzf_dir/key-bindings.zsh"
        [[ -f "$fzf_dir/completion.zsh" ]] && source "$fzf_dir/completion.zsh"
        _fzf_sourced=1
        break
      fi
    done
    unset fzf_dir
  fi
fi

# Fallback to a git install (~/.fzf, e.g. `git clone .../fzf && install`).
# Its bin is not on PATH by default, so the checks above miss it — add the bin
# and use the modern unified `fzf --zsh` output.
if (( ! _fzf_sourced )) && [[ -d "$HOME/.fzf/bin" ]]; then
  [[ ":$PATH:" == *":$HOME/.fzf/bin:"* ]] || export PATH="$PATH:$HOME/.fzf/bin"
  if command -v fzf &>/dev/null; then
    source <(fzf --zsh)
    _fzf_sourced=1
  fi
fi
unset _fzf_sourced

