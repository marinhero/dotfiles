#--------GOTO--------------

goto() {
  repo=$1

  # Re-map blog reop
  if [[ $repo == "blog" ]]
  then
    repo="marinhero.github.io"
  fi

  dir="$HOME/Code/$repo"
  if [ -d "$dir" ]
  then
    cd "$dir"
  else
    git clone "git@github.com:marinhero/$repo" "$dir" && cd "$dir"
  fi
}
