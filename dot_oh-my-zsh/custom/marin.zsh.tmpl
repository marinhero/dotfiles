#------------ASDF VERSION MANAGER-----
# asdf v0.16+ shims must be first in PATH so they take priority over system
# binaries. Only do this when asdf is actually installed — on Termux/proot the
# toolchain comes from pkg/apt, not asdf, and an unconditional prepend leaves a
# dead ~/.asdf/shims entry on PATH.
if [[ -d "${ASDF_DATA_DIR:-$HOME/.asdf}/shims" ]]; then
  export PATH="${ASDF_DATA_DIR:-$HOME/.asdf}/shims:$PATH"
  fpath=(${ASDF_DATA_DIR:-$HOME/.asdf}/completions $fpath)
fi

