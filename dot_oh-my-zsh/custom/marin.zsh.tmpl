# cc — launch Claude Code. Pass -s to bypass permission checks.
# Model comes from the global ANTHROPIC_MODEL export above (single source of
# truth), so it is not duplicated here.
cc() {
  emulate -L zsh
  local skip=() rest=()
  local a
  for a in "$@"; do
    if [[ "$a" == "-s" ]]; then
      skip=(--dangerously-skip-permissions)
    else
      rest+=("$a")
    fi
  done
  claude "${skip[@]}" "${rest[@]}"
}
