[user]
	email = alcara_m@pm.me
  name = Marín Alcaraz

[init]
  defaultBranch = main

[core]
  editor = nvim
  excludesfile = ~/.gitignore_global

[pull]
  rebase = true

[color]
  ui = true

[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = red bold 52
	newNormal = green bold
  newHighlight = green bold 22

[color "diff"]
	meta = 11
	frag = magenta bold
	func = 146 bold
	commit = yellow bold
	old = red bold
	new = green bold
  whitespace = red reverse

[push]
  default = current

[alias]
  down = "!f(){ b=$(git rev-parse --abbrev-ref origin/HEAD 2>/dev/null); b=${b#origin/}; b=${b:-main}; git checkout \"$b\" && git merge @{-1} --ff-only; }; f"
  up = !git fetch --prune --all && git rebase
  go = !git log --graph --oneline

[filter "lfs"]
  clean = git-lfs clean %f
  smudge = git-lfs smudge %f
  required = true

[branch "master"]
  rebase = "true"

[branch "main"]
  rebase = "true"

[branch]
  autosetuprebase=always
