#!/bin/sh
# Favorite the current wallpaper
current=$(awk -F"'" 'NF >= 2 { print $2; exit }' "$HOME/.fehbg" 2>/dev/null)
[ -z "$current" ] && exit 1

mkdir -p "$HOME/.config/wallpaper"
if grep -qxF "$current" "$HOME/.config/wallpaper/favorites" 2>/dev/null; then
  notify-send "Already favorited" "$(basename "$current")"
else
  echo "$current" >> "$HOME/.config/wallpaper/favorites"
  notify-send "Wallpaper favorited" "$(basename "$current")"
fi
