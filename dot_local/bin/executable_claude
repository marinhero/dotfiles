#!/data/data/com.termux/files/usr/bin/bash
# Claude Code wrapper for Termux — runs the glibc binary from inside the
# Debian proot while keeping Termux home visible at its own absolute path so
# file paths, ~/.claude state, and project working dirs all match across the
# boundary. Survives `pkg upgrade` because it lives in $HOME, not $PREFIX.

exec proot-distro login debian \
  --bind /data/data/com.termux/files/home:/data/data/com.termux/files/home \
  --bind /sdcard:/sdcard \
  --shared-tmp \
  -- env HOME=/data/data/com.termux/files/home \
         PATH=/root/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin \
         /root/.local/bin/claude "$@"
