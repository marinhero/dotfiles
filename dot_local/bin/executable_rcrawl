#!/data/data/com.termux/files/usr/bin/bash
# rcrawl — wrapper for ~/Code/rcrawl/distill.py that sets the env to talk
# to the local llama-server pair started by `local-llm`.
#
# Run `local-llm start` first so the chat (:8090) and embed (:8091) servers
# are up. Then:
#
#   rcrawl scrape <subreddit>
#   rcrawl embed <subreddit>
#   rcrawl ask <subreddit> "<question>"
#   rcrawl query <subreddit> <terms...>
#   rcrawl stats <subreddit>
#   rcrawl list
#
# Override any of these via env if you want different ports/models:
#   USE_LLAMA, LLAMA_URL, LLAMA_EMBED_URL, EMBED_MODEL, CHAT_MODEL,
#   OLLAMA_URL, REDDIT_DISTILL_DIR.

set -eu

DISTILL="${RCRAWL_DISTILL:-$HOME/Code/rcrawl/distill.py}"
if [ ! -x "$DISTILL" ]; then
  echo "rcrawl: distill.py not found or not executable at $DISTILL" >&2
  exit 1
fi

export USE_LLAMA="${USE_LLAMA:-1}"
export LLAMA_URL="${LLAMA_URL:-http://127.0.0.1:8090}"
export LLAMA_EMBED_URL="${LLAMA_EMBED_URL:-http://127.0.0.1:8091}"
export EMBED_MODEL="${EMBED_MODEL:-nomic}"
export CHAT_MODEL="${CHAT_MODEL:-qwen3-4b}"

# Pre-flight: only `embed` and `ask` need the LLM servers. For everything
# else (scrape/query/stats/list) skip the health check entirely.
needs_chat=0
needs_embed=0
case "${1:-}" in
  ask)   needs_chat=1; needs_embed=1 ;;
  embed) needs_embed=1 ;;
esac

check() {
  curl -fsS --connect-timeout 1 --max-time 2 "$1/health" >/dev/null 2>&1
}

missing=()
[ "$needs_chat"  = "1" ] && ! check "$LLAMA_URL"       && missing+=("chat ($LLAMA_URL)")
[ "$needs_embed" = "1" ] && ! check "$LLAMA_EMBED_URL" && missing+=("embed ($LLAMA_EMBED_URL)")

if [ ${#missing[@]} -gt 0 ]; then
  printf 'rcrawl: required local-llm server(s) not reachable:\n' >&2
  for m in "${missing[@]}"; do printf '  - %s\n' "$m" >&2; done
  printf '\nStart them with:  local-llm start\nThen retry:       rcrawl %s\n' "$*" >&2
  exit 1
fi

exec "$DISTILL" "$@"
