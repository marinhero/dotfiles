# Files that should NOT be managed by chezmoi
# These files should be maintained locally on each machine

.zshrc

# Repo-only files that should stay at root
README.md
AGENTS.md
.claude/**
.gitignore

# Repo-only setup scripts (and the parent dir on Termux)
repo/scripts/**
{{- if eq .chezmoi.os "android" }}
repo
repo/**
{{- end }}

# Keep bspwm config local-only (not managed/applied by chezmoi)
.config/bspwm/**

# debian-run + local-llm are Termux-only (proot-distro / llama.cpp on Termux)
{{- if ne .chezmoi.os "android" }}
.local/bin/debian-run
.local/bin/local-llm
{{- end }}

# Desktop-only configs — skip on Termux (Android)
{{- if eq .chezmoi.os "android" }}
.config/polybar/**
.config/rofi/**
.config/sxhkd/**
.config/picom/**
.config/gtk-3.0/**
.config/ghostty/**
.gtkrc-2.0
.local/bin/st-wrapper
.local/bin/lock-screen
.local/bin/random-wallpaper
.local/bin/wallpaper-exclude
.local/bin/wallpaper-favorite
.local/bin/web-search
.local/bin/sxhkd-help
.local/share/applications/st.desktop
.local/share/applications
.local/share/applications/**
.config/btop/**
.config/btop
{{- end }}
